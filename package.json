{
  "name": "ai-travel-agent",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "start": "concurrently -P 'npm run start:server -- {@}' 'npm run start:client' --",
    "start:server": "npm run start --workspace=server --",
    "start:client": "npm run start --workspace=client"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "stylelint": "^17.12.0",
    "stylelint-config-standard": "^40.0.0"
  },
  "engines": {
    "node": ">= 22.15"
  },
  "allowScripts": {
    "core-js": false,
    "core-js-pure": false
  }
}
